{
  "name": "jira-clone-backend",
  "version": "1.0.0",
  "description": "Backend API for Jira Clone application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "bun test",
    "test:jest": "jest",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
